# Tatum API Configuration
TATUM_API_KEY=your_tatum_api_key_here
TATUM_TESTNET=true

# Walrus Configuration (must use NEXT_PUBLIC_ prefix for browser access)
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# AI Configuration (NVIDIA NIM — Nemotron 120B)
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# AI Fallback (Nemotron via OpenRouter free tier)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Sui Network Configuration
SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_PACKAGE_ID=0x29198b8ae874e4dcee4659e6e8556e0c5084e6839740f42f92e246aaed1346d6

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
